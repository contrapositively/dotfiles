[core]
    editor = "nvim"
[init]
	defaultBranch = "main"
[commit]
    template = "~/.gitcommit"
[includeIf "gitdir:~/proj/"]
    path = "~/proj/.gitconfig"
[includeIf "gitdir:~/.config/"]
    path = "~/.config/.gitconfig"
[difftool]
    prompt = false
[diff]
    tool = nvimdiff
[difftool "nvimdiff"]
    cmd = "nvim -d \"$LOCAL\" \"$REMOTE\""
[alias]
    l = log --pretty=format:'%C(yellow)%h %ad%C(reset)%C(red)%d%C(reset) %s %C(blue)[%an]%C(reset)' --graph --date=short
    b = branch --format='%(color:yellow)%(committerdate:relative)%(color:reset) %(color:red)%(upstream:short): %(refname:short)%(color:reset) %(contents:subject) %(color:blue)[%(authorname)]%(color:reset)'

    ad = add
    ada = add --all                                                                        # Update all tracked files
    adu = add --update                                                                     # Update all tracked files
    adp = add --patch                                                                      # Update all tracked files

    df = diff
    dftl = difftool
    dftls = difftool --staged HEAD
    dfs = diff --staged HEAD                                                               # Diff staged changes with the last commit

    cm = commit
    cma = commit --all                                                                     # Commit, updating all tracked files
    cmlast = commit --amend --no-edit                                                      # Fold current changes into the last commit

    sa = stash
    sabr = stash branch
    wip = stash push --patch --message                                                     # Stash working changes

    rb = rebase
    rbi = rebase --interactive                                                             # Prune the commit history
    squash = '~f() { git reset --soft HEAD~"$1"; git commit; }; f'                         # Squash the last few commits

    me = merge
    meq = merge --squash                                                                   # Merge, squashing all replayed commits and staging them
    
    lo = log
    last = log -1 HEAD --stat                                                              # Details of the last commit

    fe = fetch
    sync = fetch --all --prune                                                             # Updated all remote references

    untrack = rm --cached                                                                  # Stop tracking a file

    br = branch
    brd = branch --delete
    brm = branch --move

    co = checkout
    sw = switch
    swc = switch --create                                                                  # Create a new branch
    swkw = "!f() { git branch | grep $@ | xargs git switch; }; f"                          # Switch to a branch with keywords

    sm = submodule
    smst = submodule status
    smad = submodule add
    smin = submodule init
    smud = submodule update
    smco = submodule checkout
    smrb = submodule rebase
    smme = submodule merge

    no = notes
    in = init
    re = reset
    cl = clone
    ro = remote
    st = status
    gr = grep
