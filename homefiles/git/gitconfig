[core]
    editor = "nvim"
[init]
	defaultBranch = "main"
[commit]
    template = "~/.gitcommit"
[alias]
# Pretty commit history
    l = log --pretty=format:'%C(yellow)%h %ad%C(reset)%C(red)%d%C(reset) %s %C(blue)[%an]%C(reset)' --graph --date=short
# Fancy branch list
    b = !git for-each-ref --sort='-authordate' --format='%(authordate)%09%(objectname:short)%09%(refname)' refs/heads | sed -e 's-refs/heads/--'
## Abbr
    ad = add
    co = checkout
    st = status
    gr = grep
    df = diff
    cm = commit
    br = branch
    sw = switch
    sa = stash
    rb = rebase
    me = merge
## Workflow
    ada = add --all                                                                  # Update all tracked files
    wip = '!f() { git stash push --include-untracked && git stash branch "$1"; }; f' # New branch with current changes
    rbi = rebase --interactive                                                       # Prune the commit history
    meq = merge --squash                                                             # Merge, squashing all replayed commits and staging them
    dflast = diff --cached HEAD                                                      # Diff staged changes with the last commit
    cma = commit --amend --no-edit                                                   # Fold current changes into the last commit
## Staging
    unstage = reset HEAD --
# Last commit in detail
    last = log -1 HEAD --stat
[includeIf "gitdir:~/proj/"]
    path = "~/proj/.gitconfig"
[includeIf "gitdir:~/.config/"]
    path = "~/.config/.gitconfig"
