[includeIf "gitdir:~/proj/"]
    path = ~/proj/.gitconfig
[init]
	defaultBranch = main
[alias]
    cm = commit -m
    cam = commit -am
    d = diff
    s = status -s
    co = checkout
    cob = checkout -b
    l = log --pretty=format:"%C(yellow)%h\\ %ad%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --date=short
