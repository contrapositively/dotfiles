#!/usr/bin/env bash
set -euo pipefail
shopt -s nullglob

: "${DOTFILES_TEMPLATES:?DOTFILES_TEMPLATES is not set}"
TEMPLATE_DIR="$DOTFILES_TEMPLATES"
INSTALL_DIR="$PWD"



usage() {
    echo "Usage:"
    echo "  template path"
    echo "  template list"
    echo "  template link [--dir DIR] <label> [label ...]"
    echo "  template copy [--dir DIR] <label> [label ...]"
    exit 1
}

[[ $# -ge 1 ]] || usage

SUBCOMMAND="$1"
shift

case "$SUBCOMMAND" in
    path|link|copy|list) ;;
    *) usage ;;
esac

# --- path ---
if [[ "$SUBCOMMAND" == "path" ]]; then
    echo "$TEMPLATE_DIR"
    exit 0
fi

# --- list ---
if [[ "$SUBCOMMAND" == "list" ]]; then
    for file in "$TEMPLATE_DIR"/*; do
        [[ -d "$file" ]] && basename "$file"
    done
    exit 0
fi

out() { printf "[template-%s] %s\n" "$SUBCOMMAND" "$1"; }

LABELS=()

# --- Parse remaining arguments ---
while [[ $# -gt 0 ]]; do
    case "$1" in
        --dir)
            shift
            [[ $# -gt 0 ]] || { out "Error: --dir requires argument" >&2; exit 1; }
            INSTALL_DIR="$1"
            ;;
        *)
            LABELS+=("$1")
            ;;
    esac
    shift
done

[[ ${#LABELS[@]} -ge 1 ]] || usage

mkdir -p "$INSTALL_DIR"

for label in "${LABELS[@]}"; do
    source_dir="$TEMPLATE_DIR/$label"

    [[ -d "$source_dir" ]] || continue

    for file in "$source_dir"/*; do
        [[ -e "$file" ]] || continue
        name="$(basename "$file")"
        source="$source_dir/$name"
        target="$INSTALL_DIR/$name"
        case "$SUBCOMMAND" in
            link)
                ln -sfn "$source" "$target"
                ;;
            copy)
                cp -a "$source" "$target"
                ;;
        esac
    done
    out "$label"
done
